<%- include('partials/header') %>

  <main class="cart-page container">
    <div class="cart-header">
      <h1 class="cart-header__title">VOTRE PANIER</h1>
      <p class="cart-header__subtitle"><%= cart.length %> article<%= cart.length > 1 ? 's' : '' %> sélectionné<%= cart.length > 1 ? 's' : '' %></p>
    </div>

    <% if (cart.length > 0) { %>
      <div class="cart-layout">
        <!-- Articles -->
        <div class="cart-items">
          <% cart.forEach((item, index) => { %>
            <div class="cart-item">
              <% if (item.image_url) { %>
                <img src="<%= item.image_url %>" alt="<%= item.name %>" class="cart-item__image">
              <% } else { %>
                <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=300&q=70" alt="<%= item.name %>" class="cart-item__image">
              <% } %>
              <div class="cart-item__info">
                <div>
                  <% if (item.options && item.options.length > 0) { %>
                    <span class="cart-item__label">
                      <%= item.options.map(o => o.value).join(' / ') %>
                    </span>
                  <% } %>
                  <h3 class="cart-item__name"><%= item.name %></h3>
                </div>
                <div class="cart-item__right">
                  <!-- Quantité -->
                  <form action="/cart/update" method="POST" style="display:flex;align-items:center;">
                    <input type="hidden" name="index" value="<%= index %>">
                    <div class="quantity-selector">
                      <button type="submit" name="quantity" value="<%= item.quantity - 1 %>">
                        <span class="material-symbols-outlined">remove</span>
                      </button>
                      <span style="padding:0 1rem;font-family:var(--font-headline);font-weight:700;font-size:1rem;"><%= String(item.quantity).padStart(2, '0') %></span>
                      <button type="submit" name="quantity" value="<%= item.quantity + 1 %>">
                        <span class="material-symbols-outlined">add</span>
                      </button>
                    </div>
                  </form>
                  <div class="text-right">
                    <p class="cart-item__price"><%= (item.price * item.quantity).toFixed(2) %> €</p>
                    <form action="/cart/remove" method="POST" style="display:inline;">
                      <input type="hidden" name="index" value="<%= index %>">
                      <button type="submit" class="cart-item__remove">Supprimer</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Résumé -->
        <aside class="cart-summary">
          <h2 class="cart-summary__title">Résumé</h2>
          <div class="cart-summary__row">
            <span>Sous-total</span>
            <span><%= total.toFixed(2) %> €</span>
          </div>
          <div class="cart-summary__row">
            <span>Livraison</span>
            <span>Calculée au checkout</span>
          </div>
          <div class="cart-summary__total">
            <span class="cart-summary__total-label">Total</span>
            <span class="cart-summary__total-amount"><%= total.toFixed(2) %> €</span>
          </div>
          <div style="margin-top: 2rem;">
            <a href="/checkout" class="btn btn--primary btn--full btn--lg">Passer la Commande</a>
          </div>
          <p class="cart-summary__secure">
            <span class="material-symbols-outlined">lock</span>
            Paiement sécurisé garanti
          </p>
        </aside>
      </div>
    <% } else { %>
      <div class="empty-state">
        <span class="material-symbols-outlined empty-state__icon">shopping_bag</span>
        <p class="empty-state__text">Votre panier est vide.</p>
        <a href="/products" class="btn btn--primary">Découvrir la boutique</a>
      </div>
    <% } %>
  </main>

<%- include('partials/footer') %>
